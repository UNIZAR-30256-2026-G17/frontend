{
  "name": "frontend",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start --web",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest",
    "build": "expo export --platform web"
  },
  "dependencies": {
    "@expo/metro-runtime": "~55.0.6",
    "@expo/vector-icons": "^15.0.2",
    "@nivo/bar": "^0.99.0",
    "@nivo/core": "^0.99.0",
    "@nivo/line": "^0.99.0",
    "@nivo/pie": "^0.99.0",
    "@react-native-async-storage/async-storage": "^3.0.2",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/native-stack": "^7.14.5",
    "babel-preset-expo": "~55.0.8",
    "d3": "^7.9.0",
    "expo": "~55.0.6",
    "expo-font": "~55.0.6",
    "expo-modules-core": "~55.0.23",
    "expo-status-bar": "~55.0.4",
    "jest": "~29.7.0",
    "jest-expo": "~55.0.16",
    "leaflet": "^1.9.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-leaflet": "^5.0.0",
    "react-native": "0.83.2",
    "react-native-dotenv": "^3.4.11",
    "react-native-maps": "1.27.2",
    "react-native-popover-view": "^6.1.0",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "^0.21.0"
  },
  "private": true,
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "./jest.setup.js"
    ],
    "moduleNameMapper": {
      "\\.(css|less|scss|sass)$": "jest-transform-stub"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|expo-modules-core|expo-font|react-leaflet|leaflet|d3|@nivo/.*|internmap|delaunator|robust-predicates)"
    ]
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "jest-transform-stub": "^2.0.0",
    "react-test-renderer": "^19.2.0"
  }
}